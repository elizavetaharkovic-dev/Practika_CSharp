<Window x:Class="RentCars.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RentCars"
        mc:Ignorable="d"
        Title="Аренда авто" Height="350" Width="700">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="470*"/>
            <ColumnDefinition Width="650*"/>
        </Grid.ColumnDefinitions>
        <ListBox x:Name="CarListBox" SelectionChanged="CarListBox_SelectionChanged"/>
        <StackPanel Grid.Column="1">
            <Label Content="Срок аренды" FontSize="16"/>
            <Slider x:Name="DaysSlider" Minimum="1" Maximum="30" Value="1" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="DaysSlider_ValueChanged"/>
            <Label x:Name="DaysLabel" Content="1 день"/>
            <Button Content="Арендовать" Click="RentButton_Click" Width="150"/>
        </StackPanel>
    </Grid>
</Window>
